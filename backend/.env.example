# ── Database ──
DATABASE_URL=postgresql+asyncpg://optiflow:optiflow@localhost:5432/optiflow
DATABASE_URL_SYNC=postgresql://optiflow:optiflow@localhost:5432/optiflow

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── App ──
APP_NAME=OptiFlow
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI — Rx Parsing (Phase 5) ──
GROK_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-2-vision-1212
RX_CONFIDENCE_THRESHOLD=0.85

# ── Notifications (Phase 6) ──
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@optiflow.demo
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
OPS_ALERT_EMAIL=ops@optiflow.demo
OPS_ALERT_WHATSAPP=

# ── TAT Engine (Phase 6) ──
TAT_SWEEP_INTERVAL_MINUTES=5
ALERT_COOLDOWN_MINUTES=60

# ── SLA Defaults ──
REWORK_BUFFER_HOURS=24
DWELL_THRESHOLD_HOURS=4
